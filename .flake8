[flake8]
max-line-length = 88
# E203 and W503 conflict with Black's formatting; E501 is covered by the
# line-length check above and reported more precisely by pylint.
extend-ignore = E203,W503
max-complexity = 12
exclude =
    .git,
    .venv,
    __pycache__,
    build,
    dist
per-file-ignores =
    __init__.py:F401
